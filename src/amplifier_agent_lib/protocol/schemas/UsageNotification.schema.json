{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UsageNotification",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    },
    "inputTokens": {
      "type": "integer"
    },
    "outputTokens": {
      "type": "integer"
    },
    "cost": {
      "type": "string"
    },
    "llmDurationMs": {
      "type": "integer"
    },
    "model": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "cacheReadTokens": {
      "type": "integer"
    },
    "cacheWriteTokens": {
      "type": "integer"
    },
    "sessionCostTotal": {
      "type": "string"
    },
    "agentName": {
      "type": "string"
    }
  },
  "required": [
    "inputTokens",
    "outputTokens",
    "sessionId",
    "turnId"
  ],
  "additionalProperties": false,
  "description": "Token usage and optional cost summary for a turn."
}
